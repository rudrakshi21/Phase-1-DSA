// Single Inheritance Code//

#include <iostream>
using namespace std;

class Human
{

    protected:
    string name;
};

class Student: public Human
{
    
   int roll_no;
   
   public:
   Student(string n, int a)
   {
       name=n;
       roll_no=a;
   }
   
   void display()
   {
       cout<<name<<" "<<roll_no<<endl;
   }
};
int main() {
    Student obj("Rudrakshi",10);
    obj.display();
    

    return 0;
}



