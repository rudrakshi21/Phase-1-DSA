//Hierarchical Inheritance

#include <iostream>
using namespace std;

class Person
{
protected:
    string name;
};

class Student : public Person
{
    int fees;

public:
    Student(string n, int f)
    {
        name = n;
        fees = f;
    }

    void display()
    {
        cout << "Student: " << name << " " << fees << endl;
    }
};


class Teacher : public Person
{
    int salary;

public:
    Teacher(string n, int s)
    {
        name = n;
        salary = s;
    }

    void display()
    {
        cout << "Teacher: " << name << " " << salary << endl;
    }
};

int main()
{
    Student obj1("Rudrakshi", 25000);
    Teacher obj2("Aditya", 50000);

    obj1.display();
    obj2.display();

    return 0;
}
