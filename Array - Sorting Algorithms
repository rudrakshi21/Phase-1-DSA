// Bubble Sort//

#include <iostream>
using namespace std;

int main() {
    int arr[5]={5,4,3,2,1};
    int n=5;
     cout << "Unsorted Array: ";
    for(int i = 0; i < n; i++)
    {
        cout << arr[i] << " ";
    }

    for(int i=0;i<n;i++)
    {
        for(int j=0;j<=n-2;j++)
        {
            if(arr[j]>arr[j+1])
            {
                swap(arr[j],arr[j+1]);
            }
        }
    }
     cout << "\n Sorted Array: ";
    for(int i=0;i<n;i++)
    {
        cout<<arr[i]<<" ";
    }
    

    return 0;
}






//Insertion Sort//

#include <iostream>
using namespace std;

int main() {
    int arr[5] = {5,4,3,2,1};
    int n = 5;

    cout << "Unsorted Array: ";
    for(int i = 0; i < n; i++)
    {
        cout << arr[i] << " ";
    }

    for(int i = 1; i <= n-1; i++)
    {
        for(int j = i; j > 0; j--)
        {
            if(arr[j] < arr[j-1])
            {
                swap(arr[j], arr[j-1]);
            }
        }
    }

    cout << "\nSorted Array: ";
    for(int i = 0; i < n; i++)
    {
        cout << arr[i] << " ";
    }

    return 0;
}


//Selection Sort//

#include <iostream>
using namespace std;

int main() {
    int arr[5] = {5,4,3,2,1};
    int n = 5;

   

    for(int i = 0; i <= n-1; i++)
    {
        int min_ele_index=i;
        for(int j = i+1; j <=n-1 ; j++)
        {
            if(arr[j] < arr[min_ele_index])
            {
                min_ele_index=j;
            }
        }
        swap(arr[i],arr[min_ele_index]);
    }

    
    for(int i = 0; i < n; i++)
    {
        cout << arr[i] << " ";
    }

    return 0;
}
