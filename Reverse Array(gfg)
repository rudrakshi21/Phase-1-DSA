//Input:arr[6]={1,4,3,2,6,5}//
//Output:arr[6]={5,6,2,3,4,1}//



#include <iostream>
#include <vector>
using namespace std;

class Solution {
public:
    void reverseArray(vector<int> &arr) {
        int n = arr.size();

        // Two pointer approach
        int i = 0, j = n - 1;

        while (i < j) {
            swap(arr[i], arr[j]);
            i++;
            j--;
        }
    }
};

int main() {
    vector<int> arr = {1,4,3,2,6,5};

    Solution obj;
    obj.reverseArray(arr);

    cout << "Reversed Array: ";
    for (int x : arr) {
        cout << x << " ";
    }

    return 0;
}
